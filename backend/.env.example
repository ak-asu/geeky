# === App ===
APP_NAME=Geeky API
APP_VERSION=0.1.0
DEBUG=true
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=["*"]

# === Firebase ===
# Option 1: Path to service account JSON
FIREBASE_CREDENTIALS_PATH=
# Option 2: GCP project ID (uses Application Default Credentials)
FIREBASE_PROJECT_ID=
# Option 3: Set GOOGLE_APPLICATION_CREDENTIALS env var

# === Gemini AI ===
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIMENSIONS=768

# === ChromaDB ===
CHROMADB_HOST=chromadb
CHROMADB_PORT=8000
CHROMADB_COLLECTION_NAME=geeky_chunks

# === Redis / Celery ===
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# === Rate Limiting ===
RATE_LIMIT_PER_DAY=1000
RATE_LIMIT_BURST=50

# === Pipeline ===
PIPELINE_MAX_CONCURRENT=10
PIPELINE_TIMEOUT_SECONDS=30
CHUNK_TARGET_WORDS=1000
CHUNK_OVERLAP_WORDS=200
DEDUP_SEMANTIC_THRESHOLD=0.85
DEDUP_NEAR_THRESHOLD=0.9
ANTI_DENSITY_MAX_PER_SOURCE=50

# === RAG ===
RAG_TOP_K=10
RAG_MMR_LAMBDA=0.7
RAG_CONTEXT_MAX_TOKENS=4000
RAG_REDUNDANCY_THRESHOLD=0.92

# === Recommendation ===
REC_WEIGHT_RELEVANCE=0.4
REC_WEIGHT_CAPABILITY=0.3
REC_WEIGHT_NOVELTY=0.3

# === FSRS ===
FSRS_DESIRED_RETENTION=0.9

# === Source Polling ===
SOURCE_POLL_INTERVAL_MINUTES=60
